# Clawdia — Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# === Google Cloud ===
# Get these from Google AI Studio (https://aistudio.google.com/)
Google_AI_Studio=YOUR_GEMINI_API_KEY
Youtube_data_key=YOUR_YOUTUBE_DATA_API_KEY

# === Airtable ===
# Get from https://airtable.com/create/tokens
AIRTABLE_PERSONAL_ACCESS_TOKEN=YOUR_AIRTABLE_PAT

# === Telegram (optional — for notifications) ===
Telegram_access_token=YOUR_TELEGRAM_BOT_TOKEN
Telegram_chat_id=YOUR_TELEGRAM_CHAT_ID

# === YouTube Channel IDs ===
# Find at https://www.youtube.com/account_advanced
AI_Andy_Automation=YOUR_YOUTUBE_CHANNEL_ID

# === n8n (optional — for workflow automation) ===
n8n_API_KEY=YOUR_N8N_API_KEY

# === Blotato (optional — for analytics) ===
Blotato_API_KEY=YOUR_BLOTATO_API_KEY
